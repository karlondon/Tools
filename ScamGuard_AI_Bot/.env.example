# ===========================================
# ScamGuard AI Bot - Environment Configuration
# ===========================================

# --- Telegram Configuration ---
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (for receiving notifications)
# Find it by messaging @userinfobot on Telegram
OWNER_TELEGRAM_ID=your_telegram_user_id_here

# --- Telegram Userbot (monitors YOUR personal account) ---
# This lets ScamGuard monitor ALL incoming messages on your personal Telegram,
# not just messages sent to the bot. Get these from https://my.telegram.org:
#   1. Log in with your phone number
#   2. Click "API development tools"
#   3. Create an app (any name/description)
#   4. Copy the api_id and api_hash
USERBOT_ENABLED=false
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# Session file location (stores your login so you don't re-authenticate each time)
USERBOT_SESSION=data/scamguard_userbot
# Monitor mode: "all_unknown" (non-contacts), "non_contacts_only", "all_private"
USERBOT_MONITOR_MODE=all_unknown
# Auto-respond to messages (true) or just notify you (false)
USERBOT_AUTO_RESPOND=true

# --- AI Configuration ---
# Choose: "openai" or "ollama"
AI_PROVIDER=openai

# OpenAI API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama Configuration (required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- WhatsApp Configuration (Optional) ---
# WhatsApp Business API credentials
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# --- Database ---
DATABASE_PATH=data/scamguard.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/scamguard.log

# --- Scam Detection Thresholds ---
# Score 0.0 to 1.0 - messages above this are classified as scam
SCAM_THRESHOLD=0.7
# Score below this are classified as legitimate
LEGITIMATE_THRESHOLD=0.3

# --- Response Delays (seconds) ---
# Simulate human-like response times
MIN_RESPONSE_DELAY=5
MAX_RESPONSE_DELAY=120
# Increase delay for scammers over time
SCAMMER_DELAY_MULTIPLIER=1.5