# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
SITE_URL=https://gild3d.com
NEXT_PUBLIC_SITE_NAME=Gilded Companions
NEXT_PUBLIC_API_URL=https://gild3d.com/api

# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=gild3duser
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=gild3d

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters
JWT_SECRET=CHANGE_ME_minimum_32_chars_random_string
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://gild3d.com

# ─── File Storage ─────────────────────────────────────────────────────────────
# Use 'local' for Lightsail disk storage, or 's3' for AWS S3
UPLOAD_PROVIDER=local

# If using S3:
AWS_S3_BUCKET=gild3d-uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Bitcoin Payments (BTCPay Server) ─────────────────────────────────────────
# Self-host BTCPay or use a hosted instance
BTCPAY_URL=https://your-btcpay-server.com
BTCPAY_API_KEY=your_btcpay_api_key
BTCPAY_STORE_ID=your_btcpay_store_id
BTCPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Email Notifications (optional) ──────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
FROM_EMAIL=noreply@gild3d.com

# ─── Frontend (set at build time) ────────────────────────────────────────────
NEXT_PUBLIC_BTCPAY_URL=https://your-btcpay-server.com