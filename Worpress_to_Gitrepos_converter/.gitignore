# WordPress to Git Repository Converter - .gitignore

# Configuration files with credentials
config.yaml
config.yml
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
env/
ENV/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/
migration.log

# Output directory
output/
exports/

# Migration state
.migration_state.json
*.state

# OS specific
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
*.tmp
temp/
tmp/

# Test files
.pytest_cache/
.coverage
htmlcov/