# Smart Doorbell Backend - Environment Variables Template
# Copy this file to .env and fill in your values

# Application
APP_NAME=Smart Doorbell API
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://doorbell:doorbell_password@localhost:5432/smart_doorbell
# For SQLite (development): sqlite:///./smart_doorbell.db

# Security
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-here-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (for biometric data)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006
# For production, use specific origins: https://yourdomain.com

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg

# Face Recognition
FACE_RECOGNITION_TOLERANCE=0.6
FACE_DETECTION_MODEL=hog  # or 'cnn' for better accuracy (slower)
MIN_FACE_SIZE=20  # minimum face size in pixels

# WebRTC / Video Streaming
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# Notifications (Optional)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
ENABLE_PUSH_NOTIFICATIONS=False

# Email (Optional - for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@smartdoorbell.com

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS=False

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/app.log

# Privacy & Compliance
AUTO_DELETE_RECORDINGS_DAYS=30
REQUIRE_CONSENT=True
ENABLE_ANALYTICS=False

# Development
RELOAD=True  # Auto-reload on code changes (development only)